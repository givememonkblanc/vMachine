APP_NAME=OKAstro Backend
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

# Database: switch to PostgreSQL in production
DATABASE_URL=sqlite+aiosqlite:///./okastro.db
# DATABASE_URL=postgresql+asyncpg://okastro:okastro@localhost:5432/okastro

CORS_ORIGINS=*

CACHE_BACKEND=memory
REDIS_URL=redis://localhost:6379/0

# API security: lifecycle endpoints (create/delete/start/stop/reboot VM)
# require X-API-Key header matching this value. Empty = disabled (dev default).
API_KEY=

OPENSTACK_AUTH_URL=https://openstack.example.com:5000/v3
OPENSTACK_USERNAME=admin
OPENSTACK_PASSWORD=change-me
OPENSTACK_PROJECT_NAME=admin
OPENSTACK_USER_DOMAIN_NAME=Default
OPENSTACK_PROJECT_DOMAIN_NAME=Default
OPENSTACK_REGION_NAME=RegionOne
OPENSTACK_INTERFACE=public
OPENSTACK_VERIFY_SSL=true

KUBERNETES_KUBECONFIG_PATH=

# VMware vCenter (for migration assessment)
# VMWARE_HOST=vcenter.example.com
# VMWARE_USER=administrator@vsphere.local
# VMWARE_PASSWORD=change-me

# OpenTelemetry / Tracing
# OTEL_ENDPOINT=http://jaeger:4317
